<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OneValley – Supporting Startups Globally</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:    #008cdc;
  --blue-dk: #0070b5;
  --blue-lt: #e0f4fd;
  --blue-bd: #9fd8f5;
  --white:   #ffffff;
  --off:     #f5f8fb;
  --text:    #0b1f2e;
  --muted:   #45647a;
  --border:  #c6e4f5;
  --fds:     'DM Serif Display',serif;
  --fbd:     'DM Sans',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--white);color:var(--text);font-family:var(--fbd);font-size:16px;line-height:1.6;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 52px;height:68px;background:#0d1b2a;border-bottom:1px solid rgba(255,255,255,0.08)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{color:rgba(255,255,255,0.6);text-decoration:none;font-size:14px;transition:color .2s}
.nav-links a:hover{color:#fff}
.nav-cta{display:flex;align-items:center;gap:12px}
.btn-ghost{color:rgba(255,255,255,0.6);text-decoration:none;font-size:14px;background:none;border:none;cursor:pointer;font-family:var(--fbd);transition:color .2s}
.btn-ghost:hover{color:#fff}
.btn-nav{background:var(--blue);color:#fff;font-size:14px;font-weight:600;font-family:var(--fbd);padding:9px 22px;border-radius:40px;text-decoration:none;border:none;cursor:pointer;transition:background .2s,transform .15s}
.btn-nav:hover{background:var(--blue-dk);transform:translateY(-1px)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:68px 24px 180px;position:relative;overflow:hidden;background:linear-gradient(160deg,#e4f4fc 0%,#f0f8fd 40%,#ffffff 100%)}

.hero-glow{position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:900px;height:560px;background:radial-gradient(ellipse,rgba(0,140,220,.1) 0%,transparent 68%);pointer-events:none}

.hero-title{font-family:var(--fds);font-size:clamp(46px,7vw,86px);font-weight:400;line-height:1.07;letter-spacing:-.02em;max-width:820px;margin-bottom:28px;color:var(--text);animation:fadeUp .7s .05s ease both;position:relative}
.hero-title em{font-style:italic;color:var(--blue)}
.hero-sub{font-size:18px;color:var(--muted);max-width:400px;line-height:1.6;margin-bottom:52px;animation:fadeUp .7s .15s ease both;position:relative}

.hero-pills{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:48px;animation:fadeUp .7s .25s ease both;position:relative}
.pills-row{display:flex;gap:10px;justify-content:center}
.pill{display:inline-flex;align-items:center;gap:8px;background:#fff;border:1.5px solid var(--border);border-radius:40px;padding:10px 22px;font-size:14px;font-weight:500;color:var(--text);cursor:pointer;text-decoration:none;transition:border-color .2s,background .2s,color .2s,transform .15s,box-shadow .2s;box-shadow:0 1px 6px rgba(0,140,220,.07)}
.pill:hover{border-color:var(--blue);background:var(--blue-lt);color:var(--blue-dk);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,140,220,.15)}

.hero-actions{display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeUp .7s .35s ease both;position:relative}
.btn-hero{background:var(--blue);color:#fff;font-size:15px;font-weight:600;font-family:var(--fbd);padding:14px 32px;border-radius:40px;text-decoration:none;border:none;cursor:pointer;transition:background .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 20px rgba(0,140,220,.3)}
.btn-hero:hover{background:var(--blue-dk);transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,140,220,.35)}
.btn-ghost2{color:var(--muted);font-size:15px;font-family:var(--fbd);text-decoration:none;display:flex;align-items:center;gap:6px;transition:color .2s}
.btn-ghost2:hover{color:var(--blue)}
.btn-ghost2 svg{transition:transform .2s}
.btn-ghost2:hover svg{transform:translateX(3px)}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

/* TRUST */
.trust{padding:26px 52px;background:#fff;border-top:1px solid var(--border);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap}
.trust-lbl{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
.trust-logos{display:flex;align-items:center;gap:40px;flex-wrap:wrap}
.trust-logo{font-size:13px;font-weight:600;color:#b8cedd;letter-spacing:.05em;white-space:nowrap;transition:color .2s}
.trust-logo:hover{color:var(--blue)}

/* FEATURES */
.features{padding:96px 52px;max-width:1200px;margin:0 auto}
.eyebrow{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;font-weight:600}
.sec-title{font-family:var(--fds);font-size:clamp(30px,4vw,50px);font-weight:400;line-height:1.1;letter-spacing:-.02em;max-width:540px;margin-bottom:52px;color:var(--text)}
.sec-title em{font-style:italic;color:var(--blue)}

.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px}
.card{background:var(--off);border:1px solid var(--border);border-radius:16px;padding:34px 28px;transition:border-color .2s,box-shadow .2s,transform .2s}
.card:hover{border-color:var(--blue-bd);box-shadow:0 8px 32px rgba(0,140,220,.1);transform:translateY(-3px)}
.card-icon{width:46px;height:46px;border-radius:12px;background:var(--blue-lt);border:1px solid var(--blue-bd);display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:18px}
.card-title{font-size:16px;font-weight:600;margin-bottom:9px;color:var(--text)}
.card-desc{font-size:14px;color:var(--muted);line-height:1.65}

/* STATS */
.stats{padding:80px 52px;background:var(--blue)}
.stats-inner{max-width:960px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:48px;text-align:center}
.stat-n{font-family:var(--fds);font-size:56px;font-weight:400;color:#fff;line-height:1;margin-bottom:8px}
.stat-l{font-size:14px;color:rgba(255,255,255,.65)}

/* CTA */
.cta{padding:112px 52px;text-align:center;background:var(--off);position:relative;overflow:hidden}

.cta h2{font-family:var(--fds);font-size:clamp(34px,5vw,62px);font-weight:400;letter-spacing:-.02em;line-height:1.1;max-width:620px;margin:0 auto 18px;color:var(--text);position:relative}
.cta h2 em{font-style:italic;color:var(--blue)}
.cta p{color:var(--muted);font-size:17px;margin-bottom:38px;position:relative}
.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative}
.btn-outline{background:#fff;color:var(--blue);font-size:15px;font-weight:600;font-family:var(--fbd);padding:14px 30px;border-radius:40px;text-decoration:none;border:1.5px solid var(--blue-bd);cursor:pointer;display:flex;align-items:center;gap:6px;transition:border-color .2s,background .2s,transform .15s}
.btn-outline:hover{border-color:var(--blue);background:var(--blue-lt);transform:translateY(-2px)}
.btn-outline svg{transition:transform .2s}
.btn-outline:hover svg{transform:translateX(3px)}

/* FOOTER */
footer{padding:38px 52px;border-top:1px solid rgba(255,255,255,0.08);background:#0d1b2a;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px}
.foot-links{display:flex;gap:28px}
.foot-links a{font-size:13px;color:rgba(255,255,255,0.5);text-decoration:none;transition:color .2s}
.foot-links a:hover{color:#fff}
.foot-copy{font-size:13px;color:rgba(255,255,255,0.3)}

/* REVEAL */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

@media(max-width:768px){
  nav{padding:0 20px}
  .nav-links{display:none}
  .features,.stats,.cta{padding:60px 20px}
  footer{padding:28px 20px;flex-direction:column;align-items:flex-start}
  .trust{padding:20px;gap:20px}
}
</style>
</head>
