<script>
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)} });
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(r => io.observe(r));
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
(function(){
  const canvas = document.getElementById('globe-canvas');
  const hero = canvas.parentElement;
  const W = hero.offsetWidth, H = hero.offsetHeight;
  const renderer = new THREE.WebGLRenderer({canvas, alpha:true, antialias:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(W, H);
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, W/H, 0.1, 100);
  camera.position.z = 2.6;

  const R = 1;

  /* sphere base */
  const sphereGeo = new THREE.SphereGeometry(R, 64, 64);
  const sphereMat = new THREE.MeshBasicMaterial({
    color: 0x008cdc, transparent: true, opacity: 0.14, side: THREE.FrontSide
  });
  scene.add(new THREE.Mesh(sphereGeo, sphereMat));

  /* lat/lon grid lines */
  const lineMat = new THREE.LineBasicMaterial({color: 0x008cdc, transparent: true, opacity: 0.85});
  const gridGroup = new THREE.Group();

  const latCount = 12, lonCount = 24, seg = 128;

  for(let i = 1; i < latCount; i++){
    const lat = (i / latCount) * Math.PI - Math.PI/2;
    const pts = [];
    for(let j = 0; j <= seg; j++){
      const lon = (j / seg) * Math.PI * 2;
      pts.push(new THREE.Vector3(
        Math.cos(lat)*Math.cos(lon)*R,
        Math.sin(lat)*R,
        Math.cos(lat)*Math.sin(lon)*R
      ));
    }
    gridGroup.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), lineMat));
  }

  for(let i = 0; i < lonCount; i++){
    const lon = (i / lonCount) * Math.PI * 2;
    const pts = [];
    for(let j = 0; j <= seg; j++){
      const lat = (j / seg) * Math.PI - Math.PI/2;
      pts.push(new THREE.Vector3(
        Math.cos(lat)*Math.cos(lon)*R,
        Math.sin(lat)*R,
        Math.cos(lat)*Math.sin(lon)*R
      ));
    }
    gridGroup.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), lineMat));
  }

  /* outer glow ring */
  const glowGeo = new THREE.SphereGeometry(R*1.02, 64, 64);
  const glowMat = new THREE.MeshBasicMaterial({
    color: 0x008cdc, transparent: true, opacity: 0.04,
    side: THREE.BackSide
  });
  scene.add(new THREE.Mesh(glowGeo, glowMat));

  scene.add(gridGroup);

  /* center globe */
  gridGroup.position.x = 0;
  scene.children.forEach(c => { c.position.x = 0; });

  let raf;
  function animate(){
    raf = requestAnimationFrame(animate);
    gridGroup.rotation.y += 0.0018;
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', ()=>{
    const W2 = hero.offsetWidth, H2 = hero.offsetHeight;
    camera.aspect = W2/H2; camera.updateProjectionMatrix();
    renderer.setSize(W2, H2);
  });
})();
</script>
